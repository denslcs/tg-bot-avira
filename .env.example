TELEGRAM_BOT_TOKEN=
SUPPORT_BOT_TOKEN=
SUPPORT_BOT_USERNAME=

# AI providers (we'll add these later step-by-step)
GEMINI_API_KEY=
GEMINI_NANO_MODEL=gemini-2.5-flash-image
GEMINI_NANO_COST_CREDITS=6
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_IMAGE_COST_CREDITS=6
IMAGE_READY_IDEAS_COST_CREDITS=20

# Генерация картинок: gemini (по умолчанию) или qwen (Qwen-Image, DashScope).
# Правка по фото и «готовые идеи» пока только через GEMINI_API_KEY.
IMAGE_GEN_BACKEND=gemini
DASHSCOPE_API_KEY=
QWEN_IMAGE_MODEL=qwen-image-2.0
QWEN_DASHSCOPE_API_V1_BASE=https://dashscope-intl.aliyuncs.com/api/v1
QWEN_IMAGE_SIZE=1024*1024
# Правка фото (Qwen-Image-Edit): см. список моделей в доке Model Studio
QWEN_IMAGE_EDIT_MODEL=qwen-image-edit-plus-2025-12-15
# QWEN_IMAGE_EDIT_SIZE=1024*1536

# Ссылки на внешнюю оплату (ЮKassa, Stripe Crypto, и т.д.). Пусто — пользователю предложат написать в поддержку.
PAY_URL_CARD_RU=
PAY_URL_CARD_INTL=
PAY_URL_CRYPTO=

OPENAI_API_KEY=

# If Gemini/OpenAI is blocked in your country, you'll put proxy URLs here later
GEMINI_PROXY_BASE_URL=
OPENAI_PROXY_BASE_URL=

# Database
DB_PATH=data/bot.sqlite3
START_CREDITS=20

# Admins and support
ADMIN_IDS=
SUPPORT_USERNAME=
SUPPORT_CHAT_ID=0
# Ветка «Отзывы» (message_thread_id); 0 = создать тему «Отзывы (анонимно)» при первом отзыве
SUPPORT_FEEDBACK_THREAD_ID=0

# Основной бот в админ-группе: отвечать из тем в личку пользователю (дубликат с support-ботом).
# Оставь 0 — ответы из топиков шлёт только support-бот; команды основного бота в группе всё равно работают.
MAIN_BOT_RELAY_SUPPORT_TOPICS=0

# Лимит сообщений в личке основного бота в сутки (UTC) без подписки. 0 = выключено.
FREE_DAILY_MESSAGE_LIMIT=0

# SLA (support-бот): порог «давно без ответа»; как часто слать напоминание в General (часы, по умолчанию 8)
SLA_WARNING_HOURS=4
SLA_ALERT_INTERVAL_HOURS=8
# Альтернатива: SLA_ALERT_INTERVAL_MINUTES=480 (если задано — имеет приоритет над часами)

# Еженедельная автосводка в группу поддержки (UTC): день недели 0=пн, час 0–23
WEEKLY_REPORT_WEEKDAY=0
WEEKLY_REPORT_HOUR_UTC=9

# Личка основного бота: защита от слишком длинных текстов и флуда
MAX_USER_MESSAGE_CHARS=1100
MAX_SUPPORT_DRAFT_TOTAL_CHARS=16000
PRIVATE_MESSAGES_PER_MINUTE=30
