TELEGRAM_BOT_TOKEN=
SUPPORT_BOT_TOKEN=
SUPPORT_BOT_USERNAME=

# Картинки: OpenRouter (FLUX/Gemini) + опционально Polza.ai (GPT Image для Universe). Ключ OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
OPENROUTER_IMAGE_COST_CREDITS=3
# Стоимость «Готовых идей» фиксирована в коде: 30 кредитов.
# FLUX Pro — только Universe (см. матрицу тарифов в img_commands).
OPENROUTER_IMAGE_MODEL_ALT=black-forest-labs/flux.2-pro
OPENROUTER_IMAGE_ALT_COST_CREDITS=20
# «Nano Banana» — SuperNova+; «Nano Banana 2» (preview) — Galaxy+.
OPENROUTER_IMAGE_GEMINI_MODEL=google/gemini-2.5-flash-image
OPENROUTER_IMAGE_GEMINI_COST_CREDITS=8
OPENROUTER_IMAGE_GEMINI_PREVIEW_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_IMAGE_GEMINI_PREVIEW_COST_CREDITS=15
# Gemini Pro («Banana Pro»): в коде для части готовых идей (например UFC/Макгрегор, «Ступени у огня») и как приоритет в цепочке выбора модели в ready-флоу. Если пусто — для этих идей подставляется fallback в img_commands (см. там).
OPENROUTER_IMAGE_GEMINI_PRO_MODEL=google/gemini-3-pro-image-preview
# Альтернатива на OpenRouter, если нужна другая Pro-модель: google/gemini-2.5-flash-image-pro
# Размер выхода для OpenRouter: по умолчанию не задаём image_size (только aspect_ratio 1:1, ~1 Мп) —
# иначе у FLUX.2 Pro в биллинге может получиться ~2.5 Мп при той же ставке «$ за мегапиксель» (например $0.075 при $0.03/Мп).
# Явно задать image_size только если нужно (см. доку модели на openrouter.ai):
# OPENROUTER_IMAGE_OUTPUT_SIZE=1K
# Кэш картинок на диске (одинаковый промпт+модель). 0 = выкл. «Ещё раз» кэш не использует.
# OPENROUTER_IMAGE_CACHE=1
# OPENROUTER_IMAGE_CACHE_DIR=data/image_cache_openrouter
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=AviraBot

# Polza.ai — GPT Image для Galaxy (1.5) и Universe (1.5 + 5). POST /v1/media. Ключ: https://polza.ai
POLZAAI_API_KEY=
# POLZAAI_API_BASE=https://polza.ai/api
# POLZA_IMAGE_MODEL_GPT_IMAGE_15=openai/gpt-image-1.5
# POLZA_IMAGE_MODEL_GPT5_IMAGE=openai/gpt-5-image
# POLZA_IMAGE_GPT_IMAGE_15_COST_CREDITS=10
# POLZA_IMAGE_GPT5_IMAGE_COST_CREDITS=12
# Polza: gpt-image-1.5 / gpt-5-image не поддерживают image_resolution — оставь закомментированным.
# POLZA_IMAGE_INPUT_RESOLUTION=

# Ссылки на внешнюю оплату (ЮKassa, Stripe Crypto, и т.д.). Пусто — пользователю предложат написать в поддержку.
PAY_URL_CARD_RU=
PAY_URL_CARD_INTL=
PAY_URL_CRYPTO=

OPENAI_API_KEY=

# If Gemini/OpenAI is blocked in your country, you'll put proxy URLs here later
GEMINI_PROXY_BASE_URL=
OPENAI_PROXY_BASE_URL=

# Database
DB_PATH=data/bot.sqlite3
START_CREDITS=20
# Опционально: второе сообщение в ЛС сразу после экрана /start (новости, новый промпт). Пусто = не показывать.
START_ANNOUNCEMENT=
# Картинка к объявлению (путь от корня проекта или абсолютный); подпись — START_ANNOUNCEMENT, до 1024 симв. Можно только картинку без текста.
START_ANNOUNCEMENT_IMAGE=

# Admins and support
ADMIN_IDS=
SUPPORT_USERNAME=
SUPPORT_CHAT_ID=0
# Ветка «Отзывы» (message_thread_id); 0 = создать тему «Отзывы (анонимно)» при первом отзыве
SUPPORT_FEEDBACK_THREAD_ID=0

# --- Уведомления админам о покупках (форум с темами по тарифам) ---
# Сейчас бот сам фиксирует только оплату ⭐ Telegram Stars (invoice в боте).
# Кнопки «карта ₽ / $ / крипта» ведут на внешние ссылки — событие в бот не приходит, уведомление в чат не уйдёт,
# пока не подключишь кассу (webhook) к этому боту.
#
# Что сделать:
# 1) Создай супергруппу с топиками (тип «форум») или возьми готовую.
# 2) Добавь в неё ОСНОВНОГО бота (тот же токен, что и для пользователей); выдай право отправлять сообщения и писать в темах.
# 3) Создай темы (названия любые): Starter, Nova, SuperNova, Galaxy, Universe и «Бонусы / пакеты».
# 4) Узнай chat_id группы: перешли пост из группы боту @RawDataBot / @getidsbot (часто -100…).
# 5) Узнай message_thread_id каждой темы: ссылка «к сообщению» внутри темы, или те же боты / клиент с «копировать ID».
# 6) Впиши значения в .env ниже и перезапусти бота.
# 7) Проверь тестовой покупкой Stars — в нужной теме должно появиться сообщение с типом оплаты «Звёзды».
#
# ADMIN_SALES_NOTIFY_CHAT_ID=0
# ADMIN_SALES_THREAD_STARTER=0
# ADMIN_SALES_THREAD_NOVA=0
# ADMIN_SALES_THREAD_SUPERNOVA=0
# ADMIN_SALES_THREAD_GALAXY=0
# ADMIN_SALES_THREAD_UNIVERSE=0
# ADMIN_SALES_THREAD_BONUS_PACKS=0

# Основной бот в админ-группе: отвечать из тем в личку пользователю (дубликат с support-ботом).
# Оставь 0 — ответы из топиков шлёт только support-бот; команды основного бота в группе всё равно работают.
MAIN_BOT_RELAY_SUPPORT_TOPICS=0

# SLA (support-бот): порог «давно без ответа»; как часто слать напоминание в General (часы, по умолчанию 8)
SLA_WARNING_HOURS=4
SLA_ALERT_INTERVAL_HOURS=8
# Альтернатива: SLA_ALERT_INTERVAL_MINUTES=480 (если задано — имеет приоритет над часами)

# Еженедельная автосводка в группу поддержки (UTC): день недели 0=пн, час 0–23
WEEKLY_REPORT_WEEKDAY=0
WEEKLY_REPORT_HOUR_UTC=9

# Личка основного бота: защита от слишком длинных текстов и флуда
MAX_USER_MESSAGE_CHARS=1100
MAX_SUPPORT_DRAFT_TOTAL_CHARS=16000
PRIVATE_MESSAGES_PER_MINUTE=30
